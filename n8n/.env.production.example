# ==============================================================================
# n8n Production / Staging Environment Variables
#
# Copy this file to .env.production (or .env.staging) and fill in values.
# Never commit the filled-in file to version control.
#
# Required variables are marked with [REQUIRED].
# ==============================================================================

# -- n8n version (pin to a specific tag for reproducible deployments) ----------
N8N_VERSION=latest

# -- n8n server ----------------------------------------------------------------
# [REQUIRED] Set to the public hostname where n8n will be accessed.
N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_EDITOR_BASE_URL=https://n8n.example.com/
GENERIC_TIMEZONE=UTC

# [REQUIRED] Encryption key for stored credentials. Generate with:
#   openssl rand -hex 32
# Back this up securely — losing it makes all stored credentials unrecoverable.
N8N_ENCRYPTION_KEY=

# -- PostgreSQL ----------------------------------------------------------------
# [REQUIRED] Database credentials for the n8n backend.
POSTGRES_USER=n8n
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

# -- Execution data retention --------------------------------------------------
# Hours to keep execution data before pruning (default: 168 = 7 days).
EXECUTIONS_DATA_MAX_AGE=168

# -- AI -----------------------------------------------------------------------
AI_PROVIDER=openai
OPENAI_API_KEY=
GOOGLE_API_KEY=
# OPENAI_MODEL_ALERT_CLASSIFICATION=
# OPENAI_MODEL_DAILY_SUMMARY=
# OPENAI_MODEL_VIDEO_SCRIPT=
# OPENAI_MODEL_YOUTUBE_METADATA=

# -- Media mode ----------------------------------------------------------------
MEDIA_MODE=image_video
# AI_IMAGE_COUNT=1
# OPENAI_TTS_VOICE=alloy
# GOOGLE_TTS_VOICE=en-US-Chirp3-HD-Aoede
# AI_TTS_VOICE=
# GOOGLE_TTS_LANGUAGE_CODE=

# -- Render provider -----------------------------------------------------------
# Set to 'shotstack' or 'creatomate' when video rendering is desired.
RENDER_PROVIDER=
# SHOTSTACK_API_KEY=
# CREATOMATE_API_KEY=
# CREATOMATE_TEMPLATE_ID=

# -- Telegram ------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -- Discord -------------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# -- GitHub publishing ---------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=ModernContentPlatform

# -- News / data sources -------------------------------------------------------
NEWS_API_KEY=

# -- Cloudflare D1 (used by n8n HTTP Request nodes) ---------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=
