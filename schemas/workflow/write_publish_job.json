{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "write_publish_job",
  "title": "Write Publish Job Payload",
  "description": "Payload for POST /api/internal/publish-jobs. Creates a new publish job or updates an existing one.",
  "type": "object",
  "properties": {
    "topic_slug": {
      "type": "string",
      "enum": ["crypto", "finance", "economy", "health", "ai", "energy", "technology"],
      "description": "Topic slug identifier."
    },
    "date_key": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date key in YYYY-MM-DD format."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "success", "failed", "retrying"],
      "default": "pending",
      "description": "Job status."
    },
    "triggered_by": {
      "type": ["string", "null"],
      "enum": ["schedule", "manual", "retry", null],
      "description": "What triggered this publish job."
    },
    "workflow_run_id": {
      "type": ["string", "null"],
      "description": "n8n execution ID for traceability."
    },
    "error_message": {
      "type": ["string", "null"],
      "description": "Error message if the job failed."
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Attempt number for this topic/day. Defaults to 1; the orchestrator increments this for retries."
    },
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "When present, update the existing job instead of creating a new one."
    }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "description": "Create a new publish job",
      "required": ["topic_slug", "date_key"],
      "not": { "required": ["id"] }
    },
    {
      "description": "Update an existing publish job",
      "required": ["id", "topic_slug", "date_key", "status"]
    }
  ],
  "examples": [
    {
      "topic_slug": "crypto",
      "date_key": "2025-01-15",
      "status": "pending",
      "triggered_by": "schedule"
    },
    {
      "id": 42,
      "status": "success",
      "topic_slug": "crypto",
      "date_key": "2025-01-15"
    }
  ]
}
