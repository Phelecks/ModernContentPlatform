{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "write_openai_usage_log",
  "title": "Write OpenAI Usage Log Payload",
  "description": "Payload for POST /api/internal/openai-usage-log. Records one OpenAI task execution attempt for observability and cost analysis.",
  "type": "object",
  "required": ["task", "model"],
  "properties": {
    "task": {
      "type": "string",
      "enum": [
        "alertClassification",
        "timelineFormatting",
        "dailySummary",
        "articleGeneration",
        "expectationCheck",
        "tomorrowOutlook",
        "videoScript",
        "youtubeMetadata"
      ]
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "workflow_name": {
      "type": ["string", "null"],
      "maxLength": 200
    },
    "execution_id": {
      "type": ["string", "number", "null"]
    },
    "topic_slug": {
      "type": ["string", "null"],
      "enum": ["crypto", "finance", "economy", "health", "ai", "energy", "technology", null]
    },
    "date_key": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "prompt_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "completion_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": ["ok", "error", "retry"],
      "default": "ok"
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "error_code": {
      "type": ["string", "null"],
      "maxLength": 100
    },
    "error_message": {
      "type": ["string", "null"]
    },
    "request_latency_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "estimated_cost_usd": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "metadata_json": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "error" } },
        "required": ["status"]
      },
      "then": {
        "required": ["error_message"]
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "retry" } },
        "required": ["status"]
      },
      "then": {
        "required": ["error_message"]
      }
    }
  ],
  "examples": [
    {
      "task": "dailySummary",
      "model": "gpt-4o",
      "workflow_name": "Daily — 02 Generate Summary",
      "execution_id": "199248",
      "topic_slug": "finance",
      "date_key": "2026-04-16",
      "prompt_tokens": 1420,
      "completion_tokens": 680,
      "total_tokens": 2100,
      "status": "ok",
      "retry_count": 0,
      "request_latency_ms": 3420,
      "estimated_cost_usd": 0.0184,
      "metadata_json": "{\"n8n_node\":\"Generate Summary with AI\",\"provider\":\"openai\"}"
    },
    {
      "task": "alertClassification",
      "model": "gpt-4o-mini",
      "workflow_name": "Intraday — 05 AI Classification",
      "execution_id": "199312",
      "status": "retry",
      "retry_count": 1,
      "error_code": "rate_limit_exceeded",
      "error_message": "429 Rate limit hit, retrying",
      "request_latency_ms": 1200
    }
  ]
}
