{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "write_rerun_log",
  "title": "Write Rerun Log Payload",
  "description": "Payload for POST /api/internal/rerun-log. Records one operator-initiated rerun or recovery attempt for observability and idempotency tracking.",
  "type": "object",
  "required": ["rerun_type", "topic_slug", "date_key", "source_table"],
  "properties": {
    "rerun_type": {
      "type": "string",
      "enum": ["daily_publish", "social_publish", "youtube_upload", "alert_delivery", "intraday_workflow"],
      "description": "Category of operation being rerun."
    },
    "topic_slug": {
      "type": "string",
      "enum": ["crypto", "finance", "economy", "health", "ai", "energy", "technology"]
    },
    "date_key": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "source_table": {
      "type": "string",
      "enum": ["publish_jobs", "social_publish_log", "meta_social_publish_log", "youtube_publish_log", "alerts", "workflow_logs"],
      "description": "D1 table containing the failed record being retried."
    },
    "source_id": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Row ID from the source table. Null when retrying a category rather than a specific record."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "success", "failed", "skipped"],
      "default": "pending"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 1
    },
    "triggered_by": {
      "type": "string",
      "enum": ["operator", "schedule", "auto"],
      "default": "operator"
    },
    "workflow_run_id": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "n8n execution ID for the rerun workflow."
    },
    "error_message": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "rerun_type": "daily_publish",
      "topic_slug": "crypto",
      "date_key": "2025-01-15",
      "source_table": "publish_jobs",
      "source_id": 42,
      "status": "running",
      "attempt": 1,
      "triggered_by": "operator",
      "workflow_run_id": "exec-abc-123"
    },
    {
      "rerun_type": "youtube_upload",
      "topic_slug": "finance",
      "date_key": "2025-01-15",
      "source_table": "youtube_publish_log",
      "source_id": 7,
      "status": "failed",
      "attempt": 2,
      "triggered_by": "operator",
      "error_message": "YouTube API quota exceeded on retry"
    }
  ]
}
