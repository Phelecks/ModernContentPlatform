      "position": [1780, 500]
    },
    {
      "parameters": {},
      "id": "a1b2c3d4-0001-0001-0001-000000000012",
      "name": "No Alerts — Stop",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [2000, 600]
    }
