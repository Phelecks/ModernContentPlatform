    "Has Approved Alerts?": {
      "main": [
        [
          { "node": "08 Telegram Delivery", "type": "main", "index": 0 },
          { "node": "09 Discord Delivery", "type": "main", "index": 0 }
        ],
        [{ "node": "No Alerts — Stop", "type": "main", "index": 0 }]
