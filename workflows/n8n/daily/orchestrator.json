      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "media-mode-check",
              "leftValue": "={{ $json.media_mode }}",
              "rightValue": "image_video",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000026",
      "name": "Image Video Mode?",
