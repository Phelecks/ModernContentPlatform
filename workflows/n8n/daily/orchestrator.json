      "id": "d0e0f1a2-0000-0000-0000-000000000001",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.cloudflare.com/client/v4/accounts/{{ $vars.CF_ACCOUNT_ID }}/d1/database/{{ $vars.CF_D1_DATABASE_ID }}/query",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"sql\": \"SELECT topic_slug FROM topics WHERE is_active = 1 ORDER BY sort_order ASC\", \"params\": [] }",
        "options": {
          "timeout": 10000
        }
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000002",
      "name": "Fetch Active Topics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        460,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cloudflare-d1-credentials",
          "name": "CloudflareD1Api"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Expand the topics array into individual items for the per-topic loop.\nconst resp = $input.first().json;\nconst topics = resp?.result?.[0]?.results || [];\n\nif (topics.length === 0) {\n  throw new Error('No active topics found in D1. Aborting daily editorial run.');\n}\n\nreturn topics.map(t => ({ json: { topic_slug: t.topic_slug } }));"
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000003",
      "name": "Expand Topics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000004",
      "name": "Process Topics",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Build the topic context: topic_slug and date_key.\n// date_key can be overridden via the trigger input for backfills or manual reruns.\n// When not provided, it defaults to today's UTC date (YYYY-MM-DD).\nconst item = $input.first().json;\nconst topic_slug = item.topic_slug;\n\n// Support a date_key override passed directly to the orchestrator (e.g. from a\n// manual execution or a webhook trigger). Fall back to today's UTC date.\nconst rawDateOverride = $('Schedule Trigger').first()?.json?.date_key\n  || $execution?.resumeData?.date_key\n  || null;\nconst date_key = (rawDateOverride && /^\\d{4}-\\d{2}-\\d{2}$/.test(rawDateOverride))\n  ? rawDateOverride\n  : new Date().toISOString().slice(0, 10);\n\nreturn [{ json: { topic_slug, date_key } }];"
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000005",
      "name": "Build Topic Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.cloudflare.com/client/v4/accounts/{{ $vars.CF_ACCOUNT_ID }}/d1/database/{{ $vars.CF_D1_DATABASE_ID }}/query",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  sql: \"SELECT id, status, attempt, started_at FROM publish_jobs WHERE topic_slug = ? AND date_key = ? ORDER BY created_at DESC LIMIT 1\",\n  params: [$json.topic_slug, $json.date_key]\n} }}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000006",
      "name": "Check Existing Job",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1340,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cloudflare-d1-credentials",
          "name": "CloudflareD1Api"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Merge the job check result with the topic context.\n// Computes should_skip to prevent concurrent or duplicate runs:\n//   - skip if the latest job succeeded (no need to re-run)\n//   - skip if the latest job is still running and was started within the last 2 hours\n//     (assume an active execution is in progress; stale jobs past 2 h are allowed to retry)\nconst ctx = $('Build Topic Context').first().json;\nconst jobResp = $input.first().json;\nconst existingJob = jobResp?.result?.[0]?.results?.[0] || null;\n\nlet should_skip = false;\nlet skip_reason = null;\n\nif (existingJob) {\n  if (existingJob.status === 'success') {\n    should_skip = true;\n    skip_reason = 'already_succeeded';\n  } else if (existingJob.status === 'running' && existingJob.started_at) {\n    const startedMs = new Date(existingJob.started_at).getTime();\n    const ageMinutes = (Date.now() - startedMs) / 60000;\n    if (ageMinutes < 120) {\n      should_skip = true;\n      skip_reason = `running_active (started ${Math.round(ageMinutes)}m ago)`;\n    }\n    // If >= 120 minutes old, treat as stale and allow a fresh attempt\n  }\n}\n\nreturn [{\n  json: {\n    topic_slug: ctx.topic_slug,\n    date_key: ctx.date_key,\n    existing_job_id: existingJob?.id || null,\n    existing_job_status: existingJob?.status || null,\n    existing_job_attempt: existingJob?.attempt || 0,\n    should_skip,\n    skip_reason\n  }\n}];"
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000007",
      "name": "Merge Job Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false
          },
          "conditions": [
            {
              "leftValue": "={{ $json.should_skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000008",
      "name": "Already Succeeded Today?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1780,
        300
      ]
    },
    {
      "parameters": {},
      "id": "d0e0f1a2-0000-0000-0000-000000000009",
      "name": "Skip Topic",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        2000,
        200
      ]
    },
    {
      "parameters": {
        "url": "=https://api.cloudflare.com/client/v4/accounts/{{ $vars.CF_ACCOUNT_ID }}/d1/database/{{ $vars.CF_D1_DATABASE_ID }}/query",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  sql: \"INSERT INTO publish_jobs (topic_slug, date_key, status, attempt, triggered_by, started_at, workflow_run_id) VALUES (?, ?, 'running', ?, 'schedule', strftime('%Y-%m-%dT%H:%M:%SZ', 'now'), ?) RETURNING id\",\n  params: [\n    $json.topic_slug,\n    $json.date_key,\n    ($json.existing_job_attempt || 0) + 1,\n    $execution.id\n  ]\n} }}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000010",
      "name": "Create Publish Job",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2000,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cloudflare-d1-credentials",
          "name": "CloudflareD1Api"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Extract the publish_job_id from the INSERT RETURNING response.\nconst ctx = $('Merge Job Context').first().json;\nconst resp = $input.first().json;\nconst publish_job_id = resp?.result?.[0]?.results?.[0]?.id;\n\nif (!publish_job_id) {\n  throw new Error(`Failed to create publish_job for ${ctx.topic_slug}/${ctx.date_key}`);\n}\n\nreturn [{ json: { topic_slug: ctx.topic_slug, date_key: ctx.date_key, publish_job_id } }];"
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000011",
      "name": "Extract Publish Job ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
