    {
      "parameters": {
        "jsCode": "// Resolve the active media mode from n8n variables.\n// Defaults to 'image_video' when MEDIA_MODE is not set.\n// Throws if the mode is unknown so the pipeline fails clearly\n// rather than silently proceeding with bad config.\nconst ctx = $input.first().json;\nconst VALID_MODES = ['image_video', 'full_video'];\nconst rawMode = $vars.MEDIA_MODE ?? '';\nconst media_mode = (typeof rawMode === 'string' && rawMode.trim() !== '')\n  ? rawMode.trim()\n  : 'image_video';\n\nif (!VALID_MODES.includes(media_mode)) {\n  throw new Error(\n    `MEDIA_MODE_CONFIG_ERROR: Invalid MEDIA_MODE \"${media_mode}\". ` +\n    `Supported values: ${VALID_MODES.join(', ')}.`\n  );\n}\n\nreturn [{ json: { ...ctx, media_mode } }];"
      },
      "id": "d0e0f1a2-0000-0000-0000-000000000025",
      "name": "Check Media Mode",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3650,
        400
      ]
    },
