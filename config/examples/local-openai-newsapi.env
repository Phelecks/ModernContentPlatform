# ==============================================================================
# Example: Local Development — OpenAI + NewsAPI (Recommended v1 default)
#
# Configuration is split into three sections:
#   1. Container env (.env)   — injected into n8n container by docker-compose
#   2. n8n Credentials UI     — configured in n8n once after first startup
#   3. n8n Variables           — set in n8n Settings → Variables
#
# Cloudflare .dev.vars is separate and only needed for Pages Functions testing.
#
# This is the recommended starting point for Finance + Crypto in v1.
# Requires only an OpenAI API key and a NewsAPI key.
#
# See docs/ai-provider-media-modes.md for the full configuration guide.
# ==============================================================================


# ==============================================================================
# SECTION 1 — Container environment
# Add these to your root .env file (copy from .env.example).
# docker-compose reads .env and injects these into the n8n container.
# These are NOT n8n workflow variables and are NOT set in n8n Settings.
# ==============================================================================

OPENAI_API_KEY=sk-your-openai-api-key-here

# Passed to container for convenience; also set as n8n variable below
AI_PROVIDER=openai
MEDIA_MODE=image_video
NEWS_API_KEY=your-newsapi-api-key-here


# ==============================================================================
# SECTION 2 — n8n Credentials UI
# Create these in n8n → Credentials → New after the container starts.
# These are referenced by name in workflow JSON; naming must match exactly.
# ==============================================================================

# Name:    OpenAiApi
# Type:    OpenAI API
# API Key: (paste your OPENAI_API_KEY value)


# ==============================================================================
# SECTION 3 — n8n Settings → Variables
# Set these in n8n Settings → Variables.
# Workflows read them as $vars.VARIABLE_NAME.
# ==============================================================================

# --- AI (runtime variables) --------------------------------------------------
AI_PROVIDER=openai
AI_MODEL_STANDARD=gpt-4o
AI_MODEL_FAST=gpt-4o-mini

# --- Media mode --------------------------------------------------------------
MEDIA_MODE=image_video
# RENDER_PROVIDER not set — render step is skipped; images and narration still run
# AI_IMAGE_COUNT=1          (default: 1)

# --- Source providers --------------------------------------------------------
ENABLE_X=false
ENABLE_NEWSAPI=true
NEWS_API_KEY=your-newsapi-api-key-here

# --- GitHub (needed for daily publish workflow) ------------------------------
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=ModernContentPlatform

# --- Delivery ----------------------------------------------------------------
TELEGRAM_CHAT_ID=your-telegram-chat-id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# --- Write API (Pages Functions internal auth) -------------------------------
WRITE_API_KEY=local-dev-key

# --- Sub-workflow IDs --------------------------------------------------------
# Fill in after importing workflows into n8n (Workflows → import → note the ID).
# The daily orchestrator cannot run until all these are set.
DAILY_AGGREGATE_WORKFLOW_ID=<id-for-01_aggregate_alerts>
DAILY_SUMMARY_WORKFLOW_ID=<id-for-02_generate_summary>
DAILY_ARTICLE_WORKFLOW_ID=<id-for-03_generate_article>
DAILY_EXPECTATION_CHECK_WORKFLOW_ID=<id-for-04_generate_expectation_check>
DAILY_TOMORROW_OUTLOOK_WORKFLOW_ID=<id-for-05_generate_tomorrow_outlook>
DAILY_VIDEO_SCRIPT_WORKFLOW_ID=<id-for-06_generate_video_script>
DAILY_GENERATE_IMAGES_WORKFLOW_ID=<id-for-06b_generate_images>
DAILY_GENERATE_NARRATION_WORKFLOW_ID=<id-for-06c_generate_narration>
DAILY_RENDER_VIDEO_WORKFLOW_ID=<id-for-06d_render_video>
DAILY_YOUTUBE_METADATA_WORKFLOW_ID=<id-for-07_generate_youtube_metadata>
DAILY_VALIDATE_OUTPUTS_WORKFLOW_ID=<id-for-08_validate_outputs>
DAILY_PUBLISH_GITHUB_WORKFLOW_ID=<id-for-09_publish_to_github>
DAILY_UPDATE_D1_WORKFLOW_ID=<id-for-10_update_d1_state>
FAILURE_NOTIFIER_WORKFLOW_ID=<id-for-shared_failure_notifier>
INTRADAY_INGESTION_WORKFLOW_ID=<id-for-intraday-01>
INTRADAY_NORMALIZATION_WORKFLOW_ID=<id-for-intraday-02>
INTRADAY_DEDUPLICATION_WORKFLOW_ID=<id-for-intraday-03>
INTRADAY_CLUSTERING_WORKFLOW_ID=<id-for-intraday-04>
INTRADAY_AI_CLASSIFICATION_WORKFLOW_ID=<id-for-intraday-05>
INTRADAY_ALERT_DECISION_WORKFLOW_ID=<id-for-intraday-06>
INTRADAY_D1_PERSISTENCE_WORKFLOW_ID=<id-for-intraday-07>
INTRADAY_TELEGRAM_WORKFLOW_ID=<id-for-intraday-08>
INTRADAY_DISCORD_WORKFLOW_ID=<id-for-intraday-09>


# ==============================================================================
# SECTION 4 — Cloudflare .dev.vars
# For local Pages Functions testing only (wrangler pages dev).
# This is a separate file from .env — create it in the repo root.
# ==============================================================================

# WRITE_API_KEY=local-dev-key   (set here if testing Pages Functions locally)
