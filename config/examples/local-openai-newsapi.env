# ==============================================================================
# Example: Local Development — OpenAI + NewsAPI (Recommended v1 default)
#
# Copy relevant blocks into:
#   .dev.vars          — for local Wrangler / Pages Functions secrets
#   n8n Settings → Variables  — for n8n workflow variable resolution
#
# This is the recommended starting point for Finance + Crypto in v1.
# It requires only an OpenAI API key and a NewsAPI key.
# No X API credentials required.
# RENDER_PROVIDER is omitted — the media pipeline still generates images and
# narration, but skips the final render step and records a failed render asset.
# Set RENDER_PROVIDER=shotstack or creatomate when a render service is ready.
#
# See docs/ai-provider-media-modes.md for the full configuration guide.
# ==============================================================================


# --- Cloudflare internal write API (Pages Functions) -------------------------
# Shared secret used by n8n to authenticate POST /api/internal/* endpoints.
# For local dev, any non-empty value works.
WRITE_API_KEY=local-dev-key


# --- AI provider -------------------------------------------------------------
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here

# n8n model tier variables (set in n8n Settings → Variables, not .dev.vars)
AI_MODEL_STANDARD=gpt-4o
AI_MODEL_FAST=gpt-4o-mini


# --- Media mode --------------------------------------------------------------
MEDIA_MODE=image_video
# RENDER_PROVIDER not set — render step is skipped; images and narration still run
# AI_IMAGE_COUNT=1        (default: 1)


# --- Source providers --------------------------------------------------------
ENABLE_X=false
ENABLE_NEWSAPI=true
NEWS_API_KEY=your-newsapi-api-key-here


# --- GitHub (needed for daily publish workflow) ------------------------------
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=ModernContentPlatform


# --- Telegram ----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id


# --- Discord -----------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
