# ==============================================================================
# Example: Local Development — Google + NewsAPI
#
# Copy relevant blocks into:
#   .dev.vars          — for local Wrangler / Pages Functions secrets
#   n8n Settings → Variables  — for n8n workflow variable resolution
#
# Use this to test the Google AI provider path locally.
# Requires a Google API key with Generative Language and Imagen access.
# RENDER_PROVIDER is omitted — skips the final render step.
#
# See docs/ai-provider-media-modes.md for the full configuration guide.
# ==============================================================================


# --- Cloudflare internal write API (Pages Functions) -------------------------
WRITE_API_KEY=local-dev-key


# --- AI provider -------------------------------------------------------------
AI_PROVIDER=google
GOOGLE_API_KEY=your-google-api-key-here

# n8n model tier variables (set in n8n Settings → Variables, not .dev.vars)
AI_MODEL_STANDARD=gemini-2.5-pro
AI_MODEL_FAST=gemini-2.5-flash


# --- Media mode --------------------------------------------------------------
MEDIA_MODE=image_video
# RENDER_PROVIDER not set — render step is skipped; images and narration still run
# AI_IMAGE_COUNT=1        (default: 1)


# --- Source providers --------------------------------------------------------
ENABLE_X=false
ENABLE_NEWSAPI=true
NEWS_API_KEY=your-newsapi-api-key-here


# --- GitHub (needed for daily publish workflow) ------------------------------
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=ModernContentPlatform


# --- Telegram ----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id


# --- Discord -----------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
