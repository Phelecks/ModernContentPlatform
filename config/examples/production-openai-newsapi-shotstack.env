# ==============================================================================
# Example: Production — OpenAI + NewsAPI + Shotstack
#           Finance + Crypto v1 recommended setup
#
# Set these in n8n Settings → Variables.
# The WRITE_API_KEY and any Cloudflare secrets are set in .dev.vars (local) or
# as Cloudflare Pages secrets (production).
#
# Prerequisites:
#   - OpenAI API key with gpt-4o and gpt-image-1 access
#   - NewsAPI key (newsapi.org)
#   - Shotstack API key (shotstack.io) — for the render step
#   - GitHub personal access token with repo write access
#   - Telegram bot token and chat ID
#   - Discord webhook URL
#   - n8n workflow IDs filled in after importing workflows
#
# See docs/ai-provider-media-modes.md for the full configuration guide.
# ==============================================================================


# --- Cloudflare internal write API (Pages Functions) -------------------------
# Generate with: openssl rand -hex 32
WRITE_API_KEY=your-strong-random-write-api-key


# --- AI provider -------------------------------------------------------------
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here

# n8n model tier variables
AI_MODEL_STANDARD=gpt-4o
AI_MODEL_FAST=gpt-4o-mini


# --- Media mode --------------------------------------------------------------
MEDIA_MODE=image_video
RENDER_PROVIDER=shotstack
SHOTSTACK_API_KEY=your-shotstack-api-key-here
AI_IMAGE_COUNT=1

# n8n workflow IDs — fill in after importing the daily sub-workflows into n8n
DAILY_GENERATE_IMAGES_WORKFLOW_ID=<workflow-id-for-06b>
DAILY_GENERATE_NARRATION_WORKFLOW_ID=<workflow-id-for-06c>
DAILY_RENDER_VIDEO_WORKFLOW_ID=<workflow-id-for-06d>


# --- Source providers --------------------------------------------------------
ENABLE_X=false
ENABLE_NEWSAPI=true
NEWS_API_KEY=your-newsapi-api-key-here


# --- GitHub ------------------------------------------------------------------
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=ModernContentPlatform


# --- Telegram ----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id


# --- Discord -----------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
