# ==============================================================================
# Modern Content Platform — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control — it is excluded by .gitignore.
#
# Local development does not require all variables to be set.
# Variables marked [local] are only needed for local wrangler commands.
# Variables marked [deploy] are only needed for production deployments.
# Variables marked [n8n] are configured inside the n8n instance, not here.
# ==============================================================================


# ------------------------------------------------------------------------------
# Cloudflare — account and API access
# Required for wrangler CLI operations (migrations, deployments, D1 queries)
# [local] [deploy]
# ------------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token


# ------------------------------------------------------------------------------
# Cloudflare D1 — database identifiers
#
# Provision both databases:
#   wrangler d1 create modern-content-platform-db          (production)
#   wrangler d1 create modern-content-platform-staging-db  (staging)
#
# Copy the returned database_id values here and into wrangler.toml.
# See docs/operations/d1-provisioning.md for the full setup guide.
# [local] [deploy]
# ------------------------------------------------------------------------------
CLOUDFLARE_D1_DATABASE_ID=your-production-d1-database-id
CLOUDFLARE_D1_STAGING_DATABASE_ID=your-staging-d1-database-id


# ------------------------------------------------------------------------------
# Cloudflare Pages — project name (used in deploy scripts)
# [deploy]
# ------------------------------------------------------------------------------
CLOUDFLARE_PAGES_PROJECT_NAME=modern-content-platform


# ------------------------------------------------------------------------------
# Internal Write API — shared secret for workflow-driven D1 writes
# Used by n8n to authenticate against POST /api/internal/* endpoints.
# Generate a strong random value: openssl rand -hex 32
# [local] [n8n]
# ------------------------------------------------------------------------------
WRITE_API_KEY=your-write-api-key


# ------------------------------------------------------------------------------
# GitHub — personal access token for n8n publishing workflow
# Needs repo write access to push content files and trigger redeploys.
# [n8n]
# ------------------------------------------------------------------------------
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=your-github-org-or-username
GITHUB_REPO_NAME=ModernContentPlatform


# ------------------------------------------------------------------------------
# AI — language model API keys and model configuration used by n8n AI steps
#
# OpenAI and Google are first-class AI providers in v1.
# Set AI_PROVIDER to choose which provider is active.
#
# AI_PROVIDER supports: 'openai' (default) or 'google'
#
# Task-specific model overrides document the intended model split by task.
# These variables are forwarded to the n8n container via docker-compose.
#
# Important: current n8n workflows in this repo still read the legacy n8n
# variables AI_MODEL_STANDARD and AI_MODEL_FAST (with workflow-level fallbacks).
# Setting only OPENAI_MODEL_* here will not change workflow behavior unless you
# also map those values into n8n variables (Settings → Variables) or update the
# workflows to reference these env vars directly.
#
# For the current workflows, set these compatibility variables in n8n Settings:
#   AI_MODEL_STANDARD=gpt-4o       — editorial tasks (summary, article, script,
#                                     expectation check, tomorrow outlook)
#   AI_MODEL_FAST=gpt-4o-mini      — classification, timeline formatting, and
#                                     metadata tasks
#
# The OPENAI_MODEL_* variables below document the intended per-task model split
# and are used by app/src/utils/openaiConfig.js for local validation:
#
#   OPENAI_MODEL_ALERT_CLASSIFICATION  (default: gpt-4o-mini)  — intraday fast tier
#   OPENAI_MODEL_TIMELINE_FORMATTING   (default: gpt-4o-mini)  — intraday fast tier
#   OPENAI_MODEL_DAILY_SUMMARY         (default: gpt-4o)       — daily standard tier
#   OPENAI_MODEL_ARTICLE_GENERATION    (default: gpt-4o)       — daily standard tier
#   OPENAI_MODEL_EXPECTATION_CHECK     (default: gpt-4o)       — daily standard tier
#   OPENAI_MODEL_TOMORROW_OUTLOOK      (default: gpt-4o)       — daily standard tier
#   OPENAI_MODEL_VIDEO_SCRIPT          (default: gpt-4o)       — daily standard tier
#   OPENAI_MODEL_YOUTUBE_METADATA      (default: gpt-4o-mini)  — daily fast tier
#   OPENAI_MODEL_IMAGE_GENERATION      (default: gpt-image-1)  — daily image generation task
#   OPENAI_MODEL_TTS                   (default: gpt-4o-mini-tts) — daily TTS narration task
#
# In local n8n (docker-compose), both provider API keys and model variables are
# passed to the n8n container.
# See docs/architecture/ai-provider.md for the full AI provider guide.
# [n8n]
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key
AI_PROVIDER=openai

# Current n8n workflow compatibility variables — set these in n8n Settings → Variables
# AI_MODEL_STANDARD=gpt-4o
# AI_MODEL_FAST=gpt-4o-mini

# Intended per-task model overrides — document the desired task split / future workflow wiring
# OPENAI_MODEL_ALERT_CLASSIFICATION=gpt-4o-mini
# OPENAI_MODEL_TIMELINE_FORMATTING=gpt-4o-mini
# OPENAI_MODEL_DAILY_SUMMARY=gpt-4o
# OPENAI_MODEL_ARTICLE_GENERATION=gpt-4o
# OPENAI_MODEL_EXPECTATION_CHECK=gpt-4o
# OPENAI_MODEL_TOMORROW_OUTLOOK=gpt-4o
# OPENAI_MODEL_VIDEO_SCRIPT=gpt-4o
# OPENAI_MODEL_YOUTUBE_METADATA=gpt-4o-mini
# OPENAI_MODEL_IMAGE_GENERATION=gpt-image-1
# OPENAI_MODEL_TTS=gpt-4o-mini-tts

# GOOGLE_MODEL_ALERT_CLASSIFICATION=gemini-2.5-flash
# GOOGLE_MODEL_TIMELINE_FORMATTING=gemini-2.5-flash
# GOOGLE_MODEL_DAILY_SUMMARY=gemini-2.5-pro
# GOOGLE_MODEL_ARTICLE_GENERATION=gemini-2.5-pro
# GOOGLE_MODEL_EXPECTATION_CHECK=gemini-2.5-pro
# GOOGLE_MODEL_TOMORROW_OUTLOOK=gemini-2.5-pro
# GOOGLE_MODEL_VIDEO_SCRIPT=gemini-2.5-pro
# GOOGLE_MODEL_YOUTUBE_METADATA=gemini-2.5-flash
# GOOGLE_MODEL_IMAGE_GENERATION=gemini-2.5-flash
# GOOGLE_MODEL_TTS=en-US-Chirp3-HD-Aoede

# TTS voice selection — set in n8n Settings → Variables
# AI_TTS_VOICE applies to both providers unless a provider-specific override is set.
# OPENAI_TTS_VOICE defaults to 'alloy'. Other options: echo, fable, onyx, nova, shimmer.
# GOOGLE_TTS_VOICE defaults to 'en-US-Chirp3-HD-Aoede' (Google Cloud TTS HD Chirp3 voice).
# OPENAI_TTS_VOICE=alloy
# GOOGLE_TTS_VOICE=en-US-Chirp3-HD-Aoede
# AI_TTS_VOICE=alloy
#
# Google TTS language code — derived automatically from the first two BCP-47 segments of
# GOOGLE_TTS_VOICE (e.g. 'fr-FR-Standard-A' → 'fr-FR') unless explicitly overridden here.
# Set this only when the auto-derived code is incorrect for your chosen voice.
# GOOGLE_TTS_LANGUAGE_CODE=en-US
# AI_TTS_LANGUAGE_CODE=en-US

# ANTHROPIC_API_KEY=your-anthropic-api-key   # uncomment if using Claude in a future release


# ------------------------------------------------------------------------------
# Telegram — bot token and channel/chat IDs for alert delivery
# [n8n]
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id


# ------------------------------------------------------------------------------
# Discord — webhook URL for alert delivery
# [n8n]
# ------------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url


# ------------------------------------------------------------------------------
# Source-provider toggles — control which signal providers are active
#
# Set ENABLE_X=true and/or ENABLE_NEWSAPI=true to enable each provider.
# At least one provider must be enabled; both false is a configuration error.
#
# Supported modes:
#   hybrid       — ENABLE_X=true,  ENABLE_NEWSAPI=true   (both providers active)
#   x_only       — ENABLE_X=true,  ENABLE_NEWSAPI=false  (X sources only)
#   newsapi_only — ENABLE_X=false, ENABLE_NEWSAPI=true   (NewsAPI sources only)
#
# Required API keys:
#   ENABLE_X=true      requires X_BEARER_TOKEN
#   ENABLE_NEWSAPI=true requires NEWS_API_KEY
#
# See docs/source-provider-modes.md for the full configuration guide.
# [n8n]
# ------------------------------------------------------------------------------
ENABLE_X=false
ENABLE_NEWSAPI=true


# ------------------------------------------------------------------------------
# X (Twitter) API — bearer token for X provider
# Obtain from the X Developer Portal: https://developer.twitter.com/
# Required when ENABLE_X=true.  Leave blank (or omit) when ENABLE_X=false.
# [n8n]
# ------------------------------------------------------------------------------
# X_BEARER_TOKEN=your-x-api-bearer-token


# ------------------------------------------------------------------------------
# NewsAPI — API key for NewsAPI provider
# Obtain from https://newsapi.org/
# Required when ENABLE_NEWSAPI=true.  Leave blank (or omit) when ENABLE_NEWSAPI=false.
# [n8n]
# ------------------------------------------------------------------------------
NEWS_API_KEY=your-news-api-key
# Add additional source API keys here as workflows are configured


# ------------------------------------------------------------------------------
# Media mode — controls which video generation strategy the daily pipeline uses
#
# MEDIA_MODE selects how the daily video asset is produced.
#
# Supported modes:
#   image_video  — generate still images (06b) + TTS narration (06c), then
#                  assemble into a video. Default v1 strategy — cheaper and
#                  more reliable. Requires imageGeneration + tts capabilities.
#   full_video   — full AI-generated video. Reserved for future use. No v1
#                  provider supports this yet; selecting it will fail validation.
#
# MEDIA_MODE defaults to 'image_video' when not set.
#
# Both first-class v1 providers (openai and google) are compatible with
# image_video mode. Neither currently supports full_video mode.
#
# Set this variable in n8n Settings → Variables so the orchestrator can read
# it via $vars.MEDIA_MODE.
#
# See config/media-mode.json for the n8n-readable canonical mode config.
# See app/src/utils/mediaMode.js for validation logic and capability rules.
# [n8n]
# ------------------------------------------------------------------------------
MEDIA_MODE=image_video


# ------------------------------------------------------------------------------
# YouTube — credentials for video publishing (daily editorial workflow)
# [n8n]
# ------------------------------------------------------------------------------
# YOUTUBE_CLIENT_ID=your-youtube-oauth-client-id
# YOUTUBE_CLIENT_SECRET=your-youtube-oauth-client-secret


# ------------------------------------------------------------------------------
# Meta (Instagram / Facebook) — social publishing configuration
#
# Controls whether the platform publishes daily summary posts and high-priority
# alert stories to Instagram and/or Facebook.
#
# All Meta variables are configured in n8n Settings → Variables.
# Set the toggle variables to 'true' to activate each platform.
#
# Account requirements:
#   Instagram: Professional account (Business or Creator) linked to a Facebook
#              Page. Requires instagram_basic + instagram_content_publish permissions.
#   Facebook:  Facebook Page with admin access. Requires pages_manage_posts permission.
#
# Token notes:
#   - Use long-lived Page Access Tokens to avoid frequent re-authentication.
#   - Instagram Graph API tokens derived from a System User do not expire.
#   - Facebook Page tokens should be obtained via the Graph API Explorer and
#     converted to long-lived tokens (valid 60 days, or non-expiring with System User).
#
# See docs/architecture/meta-social-publishing.md for the full setup guide.
# [n8n]
# ------------------------------------------------------------------------------

# Enable/disable toggles (set in n8n Settings → Variables)
# ENABLE_META_INSTAGRAM=false
# ENABLE_META_FACEBOOK=false
# ENABLE_META_INSTAGRAM_STORIES=false
# ENABLE_META_FACEBOOK_STORIES=false

# Instagram credentials
# META_INSTAGRAM_USER_ID=your-instagram-user-id
# META_INSTAGRAM_TOKEN=your-instagram-graph-api-token

# Facebook credentials
# META_FACEBOOK_PAGE_ID=your-facebook-page-id
# META_FACEBOOK_PAGE_TOKEN=your-facebook-page-access-token

# Story eligibility threshold — alerts with importance_score >= this value are
# eligible for Meta story generation. Defaults to 80 when not set.
# META_ALERT_STORY_THRESHOLD=80

# n8n workflow IDs for the Meta publishing modules (set after importing workflows)
# DAILY_GENERATE_META_SOCIAL_WORKFLOW_ID=your-n8n-workflow-id
# DAILY_PUBLISH_META_WORKFLOW_ID=your-n8n-workflow-id
# INTRADAY_META_STORY_WORKFLOW_ID=your-n8n-workflow-id
